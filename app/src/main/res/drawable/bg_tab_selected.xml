<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected AND focused: keep the fill, add a bright stroke as the focus cue. -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/netflix_white" />
            <corners android:radius="18dp" />
            <stroke android:width="3dp" android:color="@color/selected_item_background" />
        </shape>
    </item>
    <!-- Selected, not focused. -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/netflix_white" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
