<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: accent fill + white stroke. White label stays readable on the accent. -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/selected_item_background" />
            <corners android:radius="18dp" />
            <stroke android:width="3dp" android:color="@color/netflix_white" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/selected_item_background" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
