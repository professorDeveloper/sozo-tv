<?xml version="1.0" encoding="utf-8"?>
<!-- Input text colour for TV fields whose background turns white on focus
     (see bg_button_tv): dark text while focused, white otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:color="#111417" />
    <item android:state_pressed="true" android:color="#111417" />
    <item android:color="#FFFFFF" />
</selector>
