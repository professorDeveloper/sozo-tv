<?xml version="1.0" encoding="utf-8"?>
<!-- Header row of the Sources screen. Lives as item 0 of the screen RecyclerView so the
     title / tabs / search all scroll up together with the provider list, and D-pad focus
     travels naturally between the search field and the rows below it. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/headerRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/textView6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/days"
        android:text="Providers"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        tools:ignore="HardcodedText" />

    <!-- Engine tabs -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTabAniyomi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_selected"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusDown="@id/etSearchProvider"
            android:paddingHorizontal="26dp"
            android:paddingVertical="10dp"
            android:text="Aniyomi"
            android:textColor="#111417"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnTabCloudstream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_tab_unselected"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusDown="@id/etSearchProvider"
            android:paddingHorizontal="26dp"
            android:paddingVertical="10dp"
            android:text="CloudStream"
            android:textColor="#CCCCCC"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Provider search — kept at the top (right under the tabs) so the field and the
         list don't fight over D-pad focus while scrolling. -->
    <EditText
        android:id="@+id/etSearchProvider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_tv"
        android:drawablePadding="8dp"
        android:hint="Search providers…"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:nextFocusUp="@id/btnTabAniyomi"
        android:nextFocusLeft="@id/btnTabAniyomi"
        android:nextFocusRight="@id/btnTabCloudstream"
        android:paddingHorizontal="16dp"
        android:paddingVertical="9dp"
        android:textColor="@color/tv_field_text"
        android:textColorHint="@color/tv_field_hint"
        android:textSize="14sp"
        tools:ignore="Autofill,LabelFor" />

    <!-- Repo filter: "All" + one chip per installed repo. Filters the provider list by
         which source/repo each provider came from. Populated at runtime. -->
    <HorizontalScrollView
        android:id="@+id/repoFilterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/repoFilterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/netflix_focus_highlight"
        android:textSize="13sp"
        android:visibility="gone"
        tools:text="Loading providers…"
        tools:visibility="visible" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="No providers available."
        android:textColor="#888888"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
