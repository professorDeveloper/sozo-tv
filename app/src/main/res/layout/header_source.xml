<?xml version="1.0" encoding="utf-8"?>
<!-- Header row of the Sources screen. Lives as item 0 of the screen RecyclerView so the
     title / tabs / shortcode / search all scroll up together with the provider list, and
     D-pad focus travels naturally between the search field and the rows below it. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/headerRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/textView6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/days"
        android:text="@string/sources"
        android:textColor="#FFFFFF"
        android:textSize="22sp" />

    <!-- Engine tabs -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTabAniyomi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_selected"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="26dp"
            android:paddingVertical="10dp"
            android:text="Aniyomi"
            android:textColor="#111417"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnTabCloudstream"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_tab_unselected"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="26dp"
            android:paddingVertical="10dp"
            android:text="CloudStream"
            android:textColor="#CCCCCC"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnTabServer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_tab_unselected"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="26dp"
            android:paddingVertical="10dp"
            android:text="Server"
            android:textColor="#CCCCCC"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Install by shortcode -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Install by shortcode"
        android:textColor="#AAAAAA"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etShortcode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_button_tv"
            android:hint="e.g. yuzono"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textColor="@color/tv_field_text"
            android:textColorHint="@color/tv_field_hint"
            android:textSize="15sp"
            tools:ignore="Autofill,LabelFor" />

        <TextView
            android:id="@+id/btnInstall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_button_accent"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="24dp"
            android:paddingVertical="11dp"
            android:text="Install"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/chipContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/netflix_focus_highlight"
        android:textSize="13sp"
        android:visibility="gone"
        tools:text="Installing 2 / 5…"
        tools:visibility="visible" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- Installed providers -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Providers"
        android:textColor="#AAAAAA"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/etSearchProvider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_button_tv"
        android:drawablePadding="8dp"
        android:hint="Search providers…"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:paddingVertical="9dp"
        android:textColor="@color/tv_field_text"
        android:textColorHint="@color/tv_field_hint"
        android:textSize="14sp"
        tools:ignore="Autofill,LabelFor" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="No providers yet. Install a shortcode above."
        android:textColor="#888888"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
