<?xml version="1.0" encoding="utf-8"?>
<!-- Whole Sources screen is one vertical RecyclerView: item 0 is the header (title, tabs,
     shortcode, provider search), the rest are provider rows. Everything scrolls together and
     D-pad focus moves between the search field and the rows without getting trapped. -->
<androidx.recyclerview.widget.RecyclerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/screenRv"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="36dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp"
    tools:background="@color/main_background"
    tools:listitem="@layout/item_ext_provider" />
